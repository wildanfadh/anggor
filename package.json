{
  "name": "anggor",
  "version": "0.1.0",
  "description": "Fast, Local-First, Provider-Agnostic Autonomous Coding Agent for the Terminal",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "anggor": "dist/anggor"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "compile": "bun build src/index.ts --compile --outfile=dist/anggor",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "check": "biome check --write --error-on-warnings . && bun run typecheck",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check:pinned-deps": "bun run scripts/check-pinned-deps.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "terminal",
    "autonomous",
    "local-first",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "1.2.12",
    "@ai-sdk/openai": "1.3.22",
    "@clack/prompts": "0.9.1",
    "@poppinss/cliui": "6.8.1",
    "ai": "4.3.0",
    "micromatch": "4.0.8",
    "picocolors": "1.1.1",
    "zod": "3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/bun": "1.1.14",
    "@types/micromatch": "4.0.10",
    "@types/node": "22.0.0",
    "husky": "9.1.7",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
