# =============================================================================
# Anggor Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# API keys can also be set in .anggor.json using "env:VAR_NAME" format.
# Environment variables take precedence over config file values.
# =============================================================================

# -----------------------------------------------------------------------------
# Provider Configuration
# -----------------------------------------------------------------------------
# Provider: openai | anthropic | google | ollama | openrouter | groq | deepseek | azure | opencode | commandcode | mimo | custom
#ANGGOR_PROVIDER=openai
#ANGGOR_MODEL=gpt-4o
#ANGGOR_API_KEY=
#ANGGOR_ENDPOINT=

# -----------------------------------------------------------------------------
# Agent Settings
# -----------------------------------------------------------------------------
# Approval mode: safe | balanced | auto
#ANGGOR_APPROVAL_MODE=balanced
#ANGGOR_MAX_ITERATIONS=15
#ANGGOR_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Context Settings
# -----------------------------------------------------------------------------
#ANGGOR_MAX_TOKENS=8000
#ANGGOR_SCAN_DEPTH=3
#ANGGOR_IGNORE_PATTERNS=node_modules,dist,.git,*.log

# -----------------------------------------------------------------------------
# Safety Settings
# -----------------------------------------------------------------------------
#ANGGOR_BLOCKED_COMMANDS=rm -rf,sudo,drop database,mkfs
#ANGGOR_ALLOWED_COMMANDS=npm,yarn,bun,go,python,node,git

# -----------------------------------------------------------------------------
# Theme Settings
# -----------------------------------------------------------------------------
#ANGGOR_THEME_PRIMARY=cyan
#ANGGOR_THEME_SECONDARY=dim
#ANGGOR_THEME_ERROR=red
#ANGGOR_THEME_SUCCESS=green

# -----------------------------------------------------------------------------
# Provider API Keys (provider-specific)
# -----------------------------------------------------------------------------
# Set the key for your chosen provider.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google / Gemini
GOOGLE_API_KEY=

# Ollama (local, no key needed — just set host if not default)
OLLAMA_HOST=http://localhost:11434

# OpenRouter
OPENROUTER_API_KEY=

# Groq
GROQ_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Azure OpenAI
#AZURE_API_KEY=

# OpenCode
#OPENCODE_API_KEY=

# CommandCode
#COMMANDCODE_API_KEY=

# Mimo
#MIMO_API_KEY=

# Mimo SGP (special endpoint with its own key)
#MIMOSGP_API_KEY=